{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    },
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server/server.js" },
    { "src": "/(.*\\..*)", "dest": "client/$1" },
    { "src": "/(.*)", "dest": "client/index.html" }
  ],
  "env": {
    "VERCEL": "1"
  },
  "crons": [
    {
      "path": "/api/cron/expire-promotions",
      "schedule": "0 2 * * *"
    }
  ]
}
