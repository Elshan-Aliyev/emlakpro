# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── Auth ──────────────────────────────────────────────────────────────────────
# Minimum 64 characters. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=<64-char-random-hex>

# ── Supabase (storage only) ───────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── Server ────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins for CORS
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Full client URL — used in password-reset email links
CLIENT_URL=https://yourdomain.com

# Server port (optional — defaults to 5000 locally; ignored on Vercel)
PORT=5000

# Set automatically by Vercel — do not set manually
# VERCEL=1

# ── SMTP (optional — mailer silently disabled if absent) ─────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=<resend-api-key>
SMTP_FROM=EmlakPro <no-reply@emlakpro.az>
ADMIN_EMAIL=admin@emlakpro.az

# ── Twilio (optional — phone verification disabled if absent) ─────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=<twilio-auth-token>
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Vercel Cron (required when cron job is enabled) ───────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=<32-char-random-hex>
